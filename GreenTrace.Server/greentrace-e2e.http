POST {{baseUrl}}
Content-Type: application/json
Authorization: Bearer {{fieldAgentToken}}

{
  "query": "mutation { createBatch(input: { organizationId: {{testOrgId}}, domainId: {{domainId}}, productId: {{productId}}, batchCode: \"GH-COC-2026-0002\", originActorId: {{actor_kofiId}}, originDate: \"2026-04-21T06:00:00Z\", originLocation: \"{\\\"lat\\\":6.690,\\\"lng\\\":-1.620,\\\"region\\\":\\\"Ashanti\\\",\\\"community\\\":\\\"Atwima\\\"}\", initialQuantity: 320, initialUnitPrice: 1.45, metadata: null }) { callResult { success message code } } }"
}

